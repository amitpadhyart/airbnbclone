<%layout('/layouts/boilerplate')%>
<style>
  #filters {
    display: flex;
    flex-wrap: nowrap;
    overflow-x: auto;
    gap: 1.5rem;
    padding: 1rem 0;
    scrollbar-width: none;
    align-items: center;
  }

  #filters::-webkit-scrollbar {
    display: none;
  }

  .filter {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    flex-shrink: 0;
    min-width: 60px;
    padding: 0.5rem 0.75rem;
    border-bottom: 2px solid transparent;
    opacity: 0.6;
    cursor: pointer;
    transition: opacity 0.2s ease, border-color 0.2s ease;
    white-space: nowrap;
  }

  .filter:hover {
    opacity: 1;
  }

  .filter.active {
    opacity: 1;
    border-bottom-color: #222;
  }

  .filter i {
    font-size: 1.4rem;
  }

  .filter p {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 500;
    color: #222;
  }

  .tax-info {
    display: none;
    font-size: 0.75rem;
  }

  .tax-toggle {
    border: 1px solid black;
    border-radius: 1rem;
    height: 4rem;
    padding: 1rem;
    margin-left: auto;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }
</style>

<div id="filters">
  <div class="filter active">
    <i class="fa-solid fa-fire"></i>
    <p>Trending</p>
  </div>
  <div class="filter">
    <i class="fa-solid fa-bed"></i>
    <p>Rooms</p>
  </div>
  <div class="filter">
    <i class="fa-solid fa-mountain-sun"></i>
    <p>Countryside</p>
  </div>
  <div class="filter">
    <i class="fa-solid fa-water"></i>
    <p>Beachfront</p>
  </div>
  <div class="filter">
    <i class="fa-solid fa-city"></i>
    <p>City</p>
  </div>
  <div class="filter">
    <i class="fa-solid fa-tree"></i>
    <p>Cabins</p>
  </div>
  <div class="filter">
    <i class="fa-solid fa-umbrella-beach"></i>
    <p>Tropical</p>
  </div>
  <div class="filter">
    <i class="fa-solid fa-building"></i>
    <p>Apartments</p>
  </div>
  <div class="filter">
    <i class="fa-solid fa-star"></i>
    <p>Top Rated</p>
  </div>
  <div class="filter">
    <i class="fa-solid fa-tag"></i>
    <p>Budget</p>
  </div>

  <div class="tax-toggle">
    <div class="form-check-reverse form-switch">
      <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
      <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
    </div>
  </div>
</div>

<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4 mt-3">
  <% for (let listing of allListing) { %>
  <div class="col">
    <a href="/listings/<%= listing._id %>" class="listing-link text-decoration-none">
      <div class="card h-100 shadow-sm">
        <img
          src="<%= listing.image && listing.image.url ? listing.image.url : 'https://placehold.co/300x200?text=No+Image' %>"
          class="card-img-top"
          alt="<%= listing.title %>"
          style="height: 20rem; object-fit: cover;"
        />
        <div class="card-body">
          <p class="card-text">
            <b><%= listing.title %></b><br>
            &#8377;<%= listing.price ? listing.price.toLocaleString('en-IN') : 'N/A' %>
            <i class="tax-info">&nbsp;+18% GST</i>
          </p>
        </div>
      </div>
    </a>
  </div>
  <% } %>
</div>

<script>
  const taxSwitch = document.getElementById('switchCheckDefault');
  const taxInfoItems = document.querySelectorAll('.tax-info');

  taxSwitch.addEventListener('change', () => {
    taxInfoItems.forEach(info => {
      info.style.display = taxSwitch.checked ? 'inline' : 'none';
    });
  });
</script>