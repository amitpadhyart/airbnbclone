<%layout('/layouts/boilerplate')%>
<h3>All Listings</h3>
<a href="/listings/new" class="btn btn-dark mb-3">+ Create New Listing</a>

<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4 mt-2">

    <% for (let listing of allListing) { %>

    <div class="col">
        <a href="/listings/<%= listing._id %>" class="listing-link text-decoration-none">
            <div class="listng-card h-100">
                <img
                    src="<%= listing.image && listing.image.url ? listing.image.url : 'https://placehold.co/300x200?text=No+Image' %>"
                    class="card-img-top"
                    alt="<%= listing.title %>"
                    style="height: 20rem; object-fit: cover;"
                />
                <div class="card-body">
                    <p class="card-text">
                        <b><%= listing.title %></b><br>
                        &#8377;<%= listing.price ? listing.price.toLocaleString('en-IN') : 'N/A' %>
                    </p>
                </div>
            </div>
        </a>
    </div>

    <% } %>
</div>
