<%layout('/layouts/boilerplate')%>

<div class="row justify-content-center my-5">
  <div class="col-lg-7 col-md-9 col-12">
    <div class="mb-4">
      <h3 class="fw-bold mb-1">Edit Listing</h3>
      <p class="text-muted small mb-0">
        Update the details of your listing below.
      </p>
    </div>

    <div class="card border-0 shadow-sm rounded-4 p-4">
      <form
        method="post"
        action="/listings/<%= listing._id %>?_method=PUT"
        novalidate
        class="needs-validation"
        enctype="multipart/form-data"
      >
        <!-- Title -->
        <div class="mb-3">
          <label for="title" class="form-label fw-semibold">Title</label>
          <input
            type="text"
            id="title"
            name="listing[title]"
            value="<%= listing.title %>"
            class="form-control"
            placeholder="Enter listing title"
            required
          />
          <div class="valid-feedback">Looks good!</div>
          <div class="invalid-feedback">Please enter a title.</div>
        </div>

        <!-- Description -->
        <div class="mb-3">
          <label for="description" class="form-label fw-semibold"
            >Description</label
          >
          <textarea
            id="description"
            name="listing[description]"
            class="form-control"
            rows="4"
            placeholder="Describe your listing"
            required
          >
<%= listing.description %></textarea
          >
          <div class="valid-feedback">Looks good!</div>
          <div class="invalid-feedback">Please enter a description.</div>
        </div>

        <!-- Image Upload -->
        <div class="mb-3">
          <label class="form-label fw-semibold">Current Image</label>
          <div class="mb-2">
            <img
              src="<%= originalImage %>"
              alt="Current listing image"
              class="img-fluid rounded-3"
              style="max-height: 200px; object-fit: contain; width: auto; display: block; margin-right: auto; margin-left: 0"
            />
          </div>
          <label for="image" class="form-label text-muted small"
            >Upload New Image (optional)</label
          >
          <input
            type="file"
            id="image"
            name="listing[image][url]"
            class="form-control"
            required
          />
          <div class="valid-feedback">Looks good!</div>
        </div>

        <!-- Price -->
        <div class="mb-3">
          <label for="price" class="form-label fw-semibold"
            >Price <span class="text-muted fw-normal">(per night)</span></label
          >
          <div class="input-group">
            <span class="input-group-text">₹</span>
            <input
              type="number"
              id="price"
              name="listing[price]"
              value="<%= listing.price || '' %>"
              class="form-control"
              placeholder="0"
              required
            />
            <div class="valid-feedback">Looks good!</div>
            <div class="invalid-feedback">Please enter a valid price.</div>
          </div>
        </div>

        <!-- Location & Country -->
        <div class="row g-3 mb-4">
          <div class="col-md-5">
            <label for="location" class="form-label fw-semibold"
              >Location</label
            >
            <input
              type="text"
              id="location"
              name="listing[location]"
              value="<%= listing.location %>"
              class="form-control"
              placeholder="City or area"
              required
            />
            <div class="valid-feedback">Looks good!</div>
            <div class="invalid-feedback">Please enter a location.</div>
          </div>
          <div class="col-md-7">
            <label for="country" class="form-label fw-semibold">Country</label>
            <input
              type="text"
              id="country"
              name="listing[country]"
              value="<%= listing.country %>"
              class="form-control"
              placeholder="Country name"
              required
            />
            <div class="valid-feedback">Looks good!</div>
            <div class="invalid-feedback">Please enter a country.</div>
          </div>
        </div>

        <!-- Submit -->
        <div class="d-grid">
          <button class="btn btn-dark btn-lg rounded-3">
            <i class="fa-solid fa-pen-to-square me-2"></i>Update Listing
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
