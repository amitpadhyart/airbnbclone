<%layout('/layouts/boilerplate')%>
<div class="row">
  <div class="col-8 offset-2">
    <h3><%= listing.title %></h3>

    <div class="card col-6 offset-2" style="width: 18rem">
      <img
        src="<%= listing.image && listing.image.url ? listing.image.url : 'https://placehold.co/300x200?text=No+Image' %>"
        class="card-img-top show-img"
        alt="<%= listing.title %>"
      />
      <div class="card-body">
        <p class="card-text">
          <b><%= listing.title %></b> <br />
          <%= listing.description %> <br />
          &#8377;<%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %> <br />
          <%= listing.location %> <br />
          <%= listing.country %> <br />
        </p>
      </div>
    </div>

    <div class="btns mt-3">
      <div class="col-1">
        <a href="/listings/<%=listing._id%>/edit" class="btn btn-dark">Edit</a>
      </div>
      <br />

      <div class="col-1">
        <form action="/listings/<%=listing._id%>?_method=DELETE" method="post">
          <button class="btn btn-dark">Delete</button>
        </form>
      </div>
    </div>
  </div>
</div>
