<%layout('/layouts/boilerplate')%>

<div class="container my-5" style="max-width: 860px;">

 
  <div class="d-flex justify-content-between align-items-start mb-4">
    <div>
      <p class="text-muted text-uppercase small tracking-wide mb-1">
        <%= listing.location %>, <%= listing.country %>
      </p>
      <h1 class="fs-2 fw-normal mb-1"><%= listing.title %></h1>
      <p class="text-muted small mb-0">
        Owned by <em><%= listing.owner.username %></em>
      </p>
    </div>

    <% if (currentUser && currentUser._id.equals(listing.owner._id)) { %>
    <div class="d-flex gap-2">
      <a href="/listings/<%= listing._id %>/edit" class="btn btn-sm btn-outline-secondary">Edit</a>
      <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
      </form>
    </div>
    <% } %>
  </div>


  <img
    src="<%= listing.image.url %>"
    alt="<%= listing.title %>"
    class="w-100 rounded-3 mb-4 object-fit-cover"
    style="height: 380px;"
  />


  <div class="row g-0 border rounded-2 overflow-hidden mb-4 text-center">
    <div class="col border-end p-3">
      <p class="text-muted text-uppercase small mb-1" style="font-size: 11px; letter-spacing: .08em;">Price / night</p>
      <p class="fs-5 fw-medium mb-0">&#8377; <%= listing.price.toLocaleString("en-IN") %></p>
    </div>
    <div class="col border-end p-3">
      <p class="text-muted text-uppercase small mb-1" style="font-size: 11px; letter-spacing: .08em;">Location</p>
      <p class="fs-5 fw-medium mb-0"><%= listing.location %></p>
    </div>
    <div class="col p-3">
      <p class="text-muted text-uppercase small mb-1" style="font-size: 11px; letter-spacing: .08em;">Country</p>
      <p class="fs-5 fw-medium mb-0"><%= listing.country %></p>
    </div>
  </div>

 
  <p class="text-muted lh-lg mb-5" style="max-width: 680px;"><%= listing.description %></p>

  <hr class="mb-4">

  <% if (currentUser) { %>
  <div class="mb-5">
    <h2 class="fs-5 fw-normal mb-3">Leave a review</h2>
    <form
      action="/listings/<%= listing._id %>/reviews"
      method="POST"
      novalidate
      class="needs-validation"
    >
      <div class="mb-3">
        <label class="form-label text-muted small text-uppercase" style="letter-spacing:.08em;">Rating</label>
        <div class="star-rating">
          <input type="radio" name="review[rating]" id="star5" value="5" required />
          <label for="star5">&#9733;</label>
          <input type="radio" name="review[rating]" id="star4" value="4" />
          <label for="star4">&#9733;</label>
          <input type="radio" name="review[rating]" id="star3" value="3" />
          <label for="star3">&#9733;</label>
          <input type="radio" name="review[rating]" id="star2" value="2" />
          <label for="star2">&#9733;</label>
          <input type="radio" name="review[rating]" id="star1" value="1" />
          <label for="star1">&#9733;</label>
        </div>
        <div class="invalid-feedback">Please select a rating.</div>
      </div>

      <div class="mb-3">
        <label for="review-comment" class="form-label text-muted small text-uppercase" style="letter-spacing:.08em;">Comment</label>
        <textarea
          name="review[comment]"
          id="review-comment"
          rows="4"
          class="form-control"
          placeholder="Share your experience…"
          required
        ></textarea>
        <div class="invalid-feedback">Please leave a comment.</div>
      </div>

      <button class="btn btn-outline-dark btn-sm px-4">Submit review</button>
    </form>
  </div>
  <% } %>

 
  <h2 class="fs-5 fw-normal mb-3">All reviews</h2>
  <div class="row row-cols-1 row-cols-md-2 g-3">
    <% for (let review of listing.reviews) { %>
    <div class="col">
      <div class="card h-100 border rounded-3 p-3">
        <div class="mb-2 text-warning" style="font-size: 15px;">
          <% for (let i = 1; i <= 5; i++) { %>
            <%= i <= review.rating ? '★' : '☆' %>
          <% } %>
        </div>
        <h5 class="card-title"><%= review.author.username%></h5>
        <p class="card-text text-muted small lh-lg mb-3"><%= review.comment %></p>
        <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
          <button type="submit" class="btn btn-link p-0 text-danger small">Delete</button>
        </form>
      </div>
    </div>
    <% } %>
  </div>

</div>  